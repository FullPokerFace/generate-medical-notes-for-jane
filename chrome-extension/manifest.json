{
  "manifest_version": 3,
  "name": "AI Notes for Jane",
  "version": "1.0",
  "description": "Clicks buttons and fills fields with AI-generated medical note summaries for Jane",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.janeapp.com/*",
    "https://generate-medical-notes-for-jane.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.janeapp.com/*"
      ],
      "js": [
        "config.js",
        "utils/waitForElement.js",
        "utils/setNativeValue.js",
        "utils/findByText.js",
        "utils/clickExpandButton.js",
        "utils/clickDuplicateMenuItem.js",
        "utils/fillSoapFields.js",
        "utils/createDuplicateNote.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icon.png"
      ],
      "matches": [
        "https://*.janeapp.com/*"
      ]
    }
  ]
}